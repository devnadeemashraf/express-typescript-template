{
  "name": "express-typescript-template",
  "version": "1.0.0",
  "description": "A Backend Template built with Express, written in TypeScript 🔥",
  "main": "dist/server.js",
  "author": "Nadeem Ashraf",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "ts-node -r tsconfig-paths/register src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint . --ext .ts",
    "test": "jest --coverage",
    "test:watch": "jest --watchAll",
    "docker:build": "docker build -t express-typescript-template .",
    "docker:run": "docker run -p 5001:5001 express-typescript-template",
    "__outdated": "yarn outdated",
    "__upgrade": "yarn upgrade"
  },
  "keywords": [
    "express",
    "typescript",
    "boilerplate",
    "api",
    "jwt",
    "authentication"
  ],
  "engines": {
    "node": ">=22.11.0"
  },
  "bugs": {
    "url": "https://github.com/devnadeemashraf/express-typescript-template/issues"
  },
  "homepage": "https://github.com/devnadeemashraf/express-typescript-template#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devnadeemashraf/express-typescript-template.git"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@types/dotenv": "^8.2.3",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.16.0",
    "globals": "^15.13.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0"
  }
}
